{
  "rules": [
    {
      "rule_id": "rule_001",
      "created_at": "2025-11-14T10:30:00Z",
      "name": "Turn off the living room fan when motion is no longer detected",
      "actions": [
        {
          "if": {
            "equals": {
              "left": {
                "device": {
                  "devices": [
                    "e541b315-e84b-403f-aa87-7a15f4ff9f99"
                  ],
                  "component": "main",
                  "capability": "motionSensor",
                  "attribute": "motion"
                }
              },
              "right": {
                "string": "inactive"
              }
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "e541b315-e84b-403f-aa87-7a15f4ff9f99"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "off"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "rule_id": "rule_002",
      "created_at": "2025-11-14T11:00:00Z",
      "name": "Turn on hallway lights when front door opens",
      "actions": [
        {
          "if": {
            "equals": {
              "left": {
                "device": {
                  "devices": [
                    "front-door-sensor-id"
                  ],
                  "component": "main",
                  "capability": "contactSensor",
                  "attribute": "contact"
                }
              },
              "right": {
                "string": "open"
              }
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "hallway-lights-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "on"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "rule_id": "rule_003",
      "created_at": "2025-11-14T09:00:00Z",
      "name": "Turn on bedroom lights at 9:00 AM every day",
      "actions": [
        {
          "if": {
            "time": {
              "at": "09:00",
              "daysOfWeek": [
                "Sun",
                "Mon",
                "Tue",
                "Wed",
                "Thu",
                "Fri",
                "Sat"
              ]
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "bedroom-light-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "on"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "rule_id": "rule_004",
      "created_at": "2025-11-14T12:00:00Z",
      "name": "Turn on the porch light at sunset",
      "actions": [
        {
          "if": {
            "time": {
              "mode": "Sunset"
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "porch-light-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "on"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Turn off the porch light at sunrise",
      "actions": [
        {
          "if": {
            "time": {
              "mode": "Sunrise"
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "porch-light-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "off"
                  }
                ]
              }
            }
          ]
        }
      ],
      "rule_id": "rule_005",
      "created_at": "2026-02-13T12:56:53.497604"
    },
    {
      "name": "Lock front door at 10 PM",
      "actions": [
        {
          "if": {
            "time": {
              "at": "22:00",
              "daysOfWeek": [
                "Mon",
                "Tue",
                "Wed",
                "Thu",
                "Fri",
                "Sat",
                "Sun"
              ]
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "front-door-lock-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "lock",
                    "command": "lock"
                  }
                ]
              }
            }
          ]
        }
      ],
      "rule_id": "rule_006",
      "created_at": "2026-02-13T12:58:23.576421"
    },
    {
      "name": "Turn on bathroom fan when humidity is greater than 60 percent",
      "actions": [
        {
          "if": {
            "greaterThan": {
              "left": {
                "device": {
                  "devices": [
                    "bathroom-fan-id"
                  ],
                  "component": "main",
                  "capability": "relativeHumidityMeasurement",
                  "attribute": "humidity"
                }
              },
              "right": {
                "number": 60
              }
            }
          },
          "then": [
            {
              "command": {
                "devices": [
                  "bathroom-fan-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "on"
                  }
                ]
              }
            }
          ]
        }
      ],
      "rule_id": "rule_007",
      "created_at": "2026-02-20T11:02:25.551886"
    },
    {
      "name": "Turn on hallway lights at 6:30 AM if off",
      "actions": [
        {
          "if": {
            "and": [
              {
                "time": {
                  "at": "06:30",
                  "daysOfWeek": [
                    "Mon",
                    "Tue",
                    "Wed",
                    "Thu",
                    "Fri",
                    "Sat",
                    "Sun"
                  ]
                }
              },
              {
                "equals": {
                  "left": {
                    "device": {
                      "devices": [
                        "hallway-lights-id"
                      ],
                      "component": "main",
                      "capability": "switch",
                      "attribute": "switch"
                    }
                  },
                  "right": {
                    "string": "off"
                  }
                }
              }
            ]
          },
          "then": [
            {
              "command": {
                "devices": [
                  "hallway-lights-id"
                ],
                "commands": [
                  {
                    "component": "main",
                    "capability": "switch",
                    "command": "on"
                  }
                ]
              }
            }
          ]
        }
      ],
      "rule_id": "rule_008",
      "created_at": "2026-02-20T11:58:59.817319"
    },
